SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — Railway підставляє DATABASE_URL автоматично
DATABASE_URL=postgres://user:password@localhost:5432/music_db

# Fallback для локальної розробки (якщо DATABASE_URL не задано)
DB_NAME=music_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

OPENAI_API_KEY=

# Cloudinary (залиш порожнім для локального сховища)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
